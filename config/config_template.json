{
    "environment": {
        "testnet": true,
        "trading_mode": "spot"  
    },
    "binance": {
        "mainnet": {
            "api_key": "your_mainnet_api_key",
            "api_secret": "your_mainnet_api_secret"
        },
        "testnet_spot": {
            "api_key": "your_testnet_spot_api_key",
            "api_secret": "your_testnet_spot_api_secret"
        },
        "testnet_futures": {
            "api_key": "your_testnet_futures_api_key",
            "api_secret": "your_testnet_futures_api_secret"
        }
    },
    "telegram": {
        "bot_token": "your_bot_token",
        "allowed_users": ["your_user_id"]
    },
    "mongodb": {
        "uri": "mongodb://localhost:27017",
        "database": "tradeasaurus"
    },
    "trading": {
        "base_currency": "USDT",
        "amount_type": "fixed",          // "fixed" or "percentage"
        "fixed_amount": 100,            // Amount in USDT if type is "fixed"
        "percentage_amount": 10,         // Percentage of balance if type is "percentage"
        "cancel_after_hours": 8,
        "pairs": ["BTCUSDT", "ETHUSDT"],
        "thresholds": {
            "daily": [1, 2, 5],
            "weekly": [5, 10, 15],
            "monthly": [13, 18, 25]
        },
        "reserve_balance": 500,
        "futures_settings": {
            "default_leverage": 5,
            "margin_type": "ISOLATED",
            "position_mode": "ONE_WAY",
            "tp_enabled": true,
            "sl_enabled": true,
            "default_tp_percent": 50,
            "default_sl_percent": 10
        }
    }
}

