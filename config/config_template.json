{
    "environment": {
        "testnet": true,
        "trading_mode": "futures"
    },
    "binance": {
        "mainnet": {
            "api_key": "your_mainnet_api_key",
            "api_secret": "your_mainnet_api_secret"
        },
        "testnet_spot": {
            "api_key": "your_testnet_spot_api_key",
            "api_secret": "your_testnet_spot_api_secret"
        },
        "testnet_futures": {
            "api_key": "your_testnet_futures_api_key",
            "api_secret": "your_testnet_futures_api_secret"
        }
    },
    "telegram": {
        "bot_token": "your_bot_token",
        "allowed_users": [1234567890]
    },
    "mongodb": {
        "uri": "mongodb://localhost:27017",
        "database": "tradeasaurus"
    },
    "trading": {
        "base_currency": "USDT",
        "amount_type": "fixed",
        "fixed_amount": 200,
        "percentage_amount": 10,
        "cancel_after_hours": 8,
        "pairs": ["BTCUSDT", "ETHUSDT"],
        "thresholds": {
            "daily": [1, 2, 5],
            "weekly": [5, 10, 15],
            "monthly": [10, 20, 30]
        },
        "reserve_balance": 500,
        "spot_settings": {
            "tp_enabled": true,
            "sl_enabled": true,
            "default_tp_percent": 5,
            "default_sl_percent": 2
        },
        "futures_settings": {
            "enabled": true,
            "default_leverage": 2,
            "margin_type": "CROSSED",
            "position_mode": "HEDGE",
            "tp_enabled": true,
            "sl_enabled": true,
            "default_tp_percent": 50,
            "default_sl_percent": 10
        }
    }
}

