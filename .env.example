# Binance API Configuration
BINANCE_SPOT_TESTNET_API_KEY=your_spot_testnet_api_key_here
BINANCE_SPOT_TESTNET_API_SECRET=your_spot_testnet_api_secret_here

BINANCE_FUTURES_TESTNET_API_KEY=your_futures_testnet_api_key_here
BINANCE_FUTURES_TESTNET_API_SECRET=your_futures_testnet_api_secret_here

BINANCE_MAINNET_API_KEY=your_mainnet_api_key_here
BINANCE_MAINNET_API_SECRET=your_mainnet_api_secret_here

# Environment Selection
BINANCE_USE_TESTNET=true  # Set to false for mainnet

# Telegram Configuration
TELEGRAM_BOT_TOKEN=TELEGRAM_BOT_TOKEN
TELEGRAM_ALLOWED_USERS=1234512345,1234512345

# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=tradeasaurus

# Trading Configuration
TRADING_BASE_CURRENCY=USDT
TRADING_ORDER_AMOUNT=100
TRADING_CANCEL_HOURS=8
TRADING_PAIRS=BTCUSDT,ETHUSDT
TRADING_THRESHOLDS_DAILY=1,2,5
TRADING_THRESHOLDS_WEEKLY=5,10,15
TRADING_THRESHOLDS_MONTHLY=10,20,30
TRADING_RESERVE_BALANCE=500  # Required USDT reserve balance

# Take Profit and Stop Loss Configuration
TRADING_TP_SL_ENABLED=true
TRADING_TP_PERCENTAGE=5%
TRADING_SL_PERCENTAGE=3%

# Lower Entry Price Protection
TRADING_ONLY_LOWER_ENTRIES=true  # Only allow new futures positions if entry price is lower than previous average

# Futures Trading Configuration
TRADING_FUTURES_LEVERAGE=3  # Default leverage for futures trading (1-5)
TRADING_FUTURES_MARGIN_MODE=isolated  # Default margin mode (isolated or cross)
