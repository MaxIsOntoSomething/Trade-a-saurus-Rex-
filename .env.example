# Environment Settings
RUNNING_IN_DOCKER=false
TRADING_TESTNET=true
TRADING_MODE=futures  # 'spot' or 'futures'

# Binance API Keys
BINANCE_MAINNET_API_KEY=your_mainnet_api_key
BINANCE_MAINNET_API_SECRET=your_mainnet_api_secret
BINANCE_TESTNET_SPOT_API_KEY=your_testnet_spot_api_key
BINANCE_TESTNET_SPOT_API_SECRET=your_testnet_spot_api_secret
BINANCE_TESTNET_FUTURES_API_KEY=your_testnet_futures_api_key
BINANCE_TESTNET_FUTURES_API_SECRET=your_testnet_futures_api_secret

# MongoDB Settings
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=tradeasaurus

# Telegram Settings
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_ALLOWED_USERS=1234567890  # Comma-separated list of user IDs

# Trading Settings
TRADING_BASE_CURRENCY=USDT
TRADING_AMOUNT_TYPE=fixed  # 'fixed' or 'percentage'
TRADING_FIXED_AMOUNT=200
TRADING_PERCENTAGE_AMOUNT=10
TRADING_CANCEL_HOURS=8
TRADING_PAIRS=BTCUSDT,ETHUSDT
TRADING_RESERVE_BALANCE=500

# Threshold Settings
TRADING_THRESHOLDS_DAILY=1,2,5
TRADING_THRESHOLDS_WEEKLY=5,10,15
TRADING_THRESHOLDS_MONTHLY=10,20,30

# Spot Settings
SPOT_TP_ENABLED=true
SPOT_SL_ENABLED=true
SPOT_DEFAULT_TP_PERCENT=5
SPOT_DEFAULT_SL_PERCENT=2

# Futures Settings
FUTURES_ENABLED=true
FUTURES_DEFAULT_LEVERAGE=2
FUTURES_MARGIN_TYPE=CROSSED  # 'CROSSED' or 'ISOLATED'
FUTURES_POSITION_MODE=HEDGE  # 'ONE_WAY' or 'HEDGE'
FUTURES_TP_ENABLED=true
FUTURES_SL_ENABLED=true
FUTURES_DEFAULT_TP_PERCENT=50
FUTURES_DEFAULT_SL_PERCENT=10

# WebSocket Settings (optional)
BINANCE_WS_KEEPALIVE=true
BINANCE_WS_TIMEOUT=60000

# Monitoring Settings
HEALTH_CHECK_PORT=8080
ENABLE_MONITORING=true

# Logging Settings
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/tradeasaurus.log

# Docker Settings
RUNNING_IN_DOCKER=True