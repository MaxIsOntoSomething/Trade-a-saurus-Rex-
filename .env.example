# Environment Settings
TRADING_TESTNET=true
TRADING_MODE=spot  # 'spot' or 'futures'

# Binance API Keys
BINANCE_MAINNET_API_KEY=your_mainnet_key
BINANCE_MAINNET_API_SECRET=your_mainnet_secret

BINANCE_TESTNET_SPOT_API_KEY=your_testnet_spot_key
BINANCE_TESTNET_SPOT_API_SECRET=your_testnet_spot_secret

BINANCE_TESTNET_FUTURES_API_KEY=your_testnet_futures_key
BINANCE_TESTNET_FUTURES_API_SECRET=your_testnet_futures_secret

# MongoDB Settings
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=tradeasaurus

# Telegram Settings
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Trading Settings
TRADING_BASE_CURRENCY=USDT
TRADING_ORDER_AMOUNT=100
TRADING_CANCEL_HOURS=8
TRADING_PAIRS=BTCUSDT,ETHUSDT
TRADING_RESERVE_BALANCE=500

# Threshold Settings
TRADING_THRESHOLDS_DAILY=1,2,5
TRADING_THRESHOLDS_WEEKLY=5,10,15
TRADING_THRESHOLDS_MONTHLY=10,20,30

# Futures Settings (only if TRADING_MODE=futures)
FUTURES_DEFAULT_LEVERAGE=5
FUTURES_MARGIN_TYPE=ISOLATED
FUTURES_POSITION_MODE=ONE_WAY
FUTURES_ALLOWED_PAIRS=BTCUSDT,ETHUSDT

# Take Profit and Stop Loss Settings (for futures)
FUTURES_TP_ENABLED=true
FUTURES_SL_ENABLED=true
FUTURES_DEFAULT_TP_PERCENT=50
FUTURES_DEFAULT_SL_PERCENT=10

# WebSocket Settings (optional)
BINANCE_WS_KEEPALIVE=true
BINANCE_WS_TIMEOUT=60000

# Monitoring Settings
HEALTH_CHECK_PORT=8080
ENABLE_MONITORING=true

# Logging Settings
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/tradeasaurus.log

# Docker Settings
RUNNING_IN_DOCKER=false
